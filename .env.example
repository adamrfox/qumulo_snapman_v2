# Copy this to .env and fill in the required values before running docker compose up.

# Port the web UI is exposed on. Change if 3003 is taken.
APP_PORT=3003

# Required: password for the auto-created admin account on first run.
ADMIN_PASSWORD=

# Database password (fine to leave as default for local installs).
DB_PASSWORD=snapman

# Required: secret for signing JWTs. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Required: Fernet key for encrypting Qumulo tokens at rest. Generate one with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=
