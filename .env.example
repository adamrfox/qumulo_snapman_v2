# Copy this to .env and fill in the required values before running docker compose up.

# Port the web UI is exposed on. Change if 3003 is taken.
APP_PORT=3003

# Required: password for the auto-created admin account on first run.
ADMIN_PASSWORD=

# Database password (fine to leave as default for local installs).
DB_PASSWORD=snapman

# Required: secret for signing JWTs. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Required: Fernet key for encrypting Qumulo tokens at rest. Generate one with:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=

# Serve the web UI over HTTPS (on the same APP_PORT) instead of plain HTTP.
# To use your own certificate, put tls.crt and tls.key in the ./certs
# directory before starting the app. If left empty, a self-signed cert is
# generated there automatically on first start -- fine for eval/internal
# use, but replace it with a real cert for anything customer-facing.
ENABLE_HTTPS=false
